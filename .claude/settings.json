{
  "permissions": {
    "allow": [
      "Edit",
      "Write",
      "Read",
      "Bash",
      "Glob",
      "Grep",
      "Bash(git checkout:*)",
      "Bash(git commit:*)",
      "Bash(scripts\\\\build.bat -debug)",
      "Bash(findstr /C:\"error\" /C:\"warning\")",
      "Bash(tee rate_limiter_refs.txt)",
      "Bash(ls -la OAuth2Backend/filters/RateLimiterFilter.*)",
      "Bash(ls -la RateLimiterFilter.*)",
      "Bash(rm -f filters/RateLimiterFilter.cc)",
      "Bash(rm -f filters/RateLimiterFilter.h)",
      "Bash(git commit -m ':*)",
      "Bash(xargs grep:*)",
      "Bash(taskkill /F /IM OAuth2Server.exe)",
      "Bash(scripts\\\\build.bat)",
      "Bash(scripts/build.bat)",
      "Bash(cmake --build . --config Release)",
      "Bash(dir OAuth2Server.exe)",
      "Bash(findstr \"OAuth2Server.exe\")",
      "Bash(cmake --build build/ --target OAuth2Server --target OAuth2Test_test)",
      "Bash(grep -E \"\\\\.\\(exe\\)$\")",
      "Bash(cmake --build build/ --target OAuth2Server --target OAuth2Test_test --config Release)",
      "Bash(cmake --build build/ --target OAuth2Test_test --config Debug)",
      "Bash(start OAuth2Server.exe)",
      "Bash(./OAuth2Server.exe)",
      "Bash(./build/Release/OAuth2Server.exe)",
      "Read(//c/Program Files/drogon/include/drogon/**)",
      "Bash(cmake --build . --config Release --target OAuth2Server)",
      "Read(//c/Program Files/drogon/include/drogon/plugins/**)",
      "Read(//usr/include/drogon/**)",
      "Bash(timeout 10 ./build/Release/OAuth2Server.exe)",
      "Read(//tmp/**)",
      "Bash(dir config.json)",
      "Bash(tasklist)",
      "Bash(findstr OAuth2Server)",
      "Bash(ldd OAuth2Server.exe)",
      "Bash(powershell -Command '& { .\\\\OAuth2Server.exe; Write-Host \"Exit code: $LASTEXITCODE\" }')",
      "Bash(taskkill //F //IM OAuth2Server.exe)",
      "Bash(curl -s -o nul -w \"%{http_code}\\\\n\" http://localhost:5555/)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "pattern": "Edit",
        "command": "clang-format -i $(git ls-files '*.cc' '*.h' '*.cpp' '*.hpp' 2>/dev/null || find . -name '*.cc' -o -name '*.h' -o -name '*.cpp' -o -name '*.hpp')",
        "allowedTools": [
          "Bash"
        ]
      }
    ],
    "PreToolUse": [
      {
        "pattern": "Bash(git commit*)",
        "command": "echo 'Running pre-commit tests...' && cd OAuth2Backend/build && ctest --output-on-failure && echo 'Tests passed, commit allowed' || (echo 'Tests failed, commit blocked' && exit 1)",
        "allowedTools": [
          "Bash"
        ]
      }
    ]
  }
}
