{
  "permissions": {
    "allow": [
      "Edit",
      "Write",
      "Read",
      "Bash",
      "Glob",
      "Grep"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit",
        "hooks": [
          {
            "type": "command",
            "command": "clang-format -i $(git ls-files '*.cc' '*.h' '*.cpp' '*.hpp' 2>/dev/null | grep -v '^OAuth2Backend/models/' || find . \\( -name '*.cc' -o -name '*.h' -o -name '*.cpp' -o -name '*.hpp' \\) -not -path '*/OAuth2Backend/models/*')"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash(git commit*)",
        "hooks": [
          {
            "type": "command",
            "command": "echo 'Running pre-commit tests...' && cd OAuth2Backend/build && ctest --output-on-failure && echo 'Tests passed, commit allowed' || (echo 'Tests failed, commit blocked' && exit 1)"
          }
        ]
      }
    ]
  }
}
